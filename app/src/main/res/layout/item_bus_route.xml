<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/table_row_background"
    android:gravity="center_vertical"
    android:minHeight="66dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/busRouteNameText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.35"
        android:gravity="center_vertical"
        android:maxLines="3"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:textColor="@color/bus_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/busPriceText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.85"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:textColor="@color/bus_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/busDurationText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.95"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:textColor="@color/bus_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/busArrivalText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.55"
        android:gravity="center_vertical"
        android:maxLines="3"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:textColor="@color/bus_text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/busWalkingDistanceText"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:textColor="@color/bus_text_primary"
        android:textSize="12sp" />
</LinearLayout>
