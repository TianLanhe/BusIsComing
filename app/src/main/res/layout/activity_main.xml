<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_page_background"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/normalTopActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/transitCodeButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minHeight="44dp"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="乘車碼"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/bus_chip_selected"
            app:cornerRadius="6dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manageRoutesButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:minHeight="44dp"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="管理路線"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/bus_chip_selected"
            app:cornerRadius="6dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/firstRunTopActions"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="start|center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/firstRunTransitCodeButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:elevation="0dp"
            android:minHeight="44dp"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="乘車碼"
            android:textColor="@color/bus_chip_selected"
            android:textSize="14sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="6dp"
            app:elevation="0dp"
            app:strokeColor="@color/bus_divider"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyRouteState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:gravity="top"
        android:orientation="vertical"
        android:paddingTop="78dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/firstRunHeadlineText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.18"
            android:text="@string/first_run_home_headline"
            android:textColor="@color/bus_text_primary"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/firstRunSampleLabelText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/first_run_sample_label"
            android:textColor="@color/bus_chip_selected"
            android:textSize="12sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/firstRunSampleRouteCard"
            layout="@layout/item_bus_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/firstRunActionGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/emptyAddRouteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/first_run_add_route" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/emptyTemporaryQueryButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/first_run_temporary_query" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/queryControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/frequentRoutesHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/frequentRoutesTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="常用路線"
                android:textColor="@color/bus_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/routePickerButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="40dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                android:text="全部"
                android:textColor="@color/bus_chip_selected"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/routeShortcutRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/routeShortcutCardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/queryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="查詢" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/resultSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/temporaryQueryContextBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bus_surface_variant"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/bus_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/sort_chip_background"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="臨時"
                    android:textColor="@color/bus_chip_selected"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/temporaryQueryContextPathText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/bus_text_primary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/temporaryQuerySaveButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minHeight="36dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp"
                    android:text="保存"
                    android:textColor="@color/bus_chip_selected"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/sortControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sortRouteButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="路線"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sortPriceButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="價格"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sortDurationButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="耗時"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sortArrivalButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="候車"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sortWalkingDistanceButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="步行"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultSummaryContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/resultSummaryText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/bus_text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultUpdatedAtText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/bus_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bus_state_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/bus_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ProgressBar
                    android:id="@+id/resultStatusProgress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/resultStatusTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bus_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resultStatusMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/bus_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/resultListContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:visibility="gone">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/resultSwipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/busRouteList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="8dp" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultRefreshOverlay"
                android:layout_width="48dp"
                android:layout_height="36dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="yes"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bus_card_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/bus_divider"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ProgressBar
                        android:id="@+id/resultRefreshProgress"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:indeterminate="true" />

                    <ImageView
                        android:id="@+id/resultRefreshSuccess"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/route_refresh_complete"
                        android:src="@drawable/ic_refresh_success"
                        android:visibility="gone"
                        app:tint="@color/bus_chip_selected" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
